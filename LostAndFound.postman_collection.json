{
  "info": {
    "name": "Lost & Found - Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "access", "value": "" },
    { "key": "refresh", "value": "" },
    { "key": "username", "value": "" },
    { "key": "email", "value": "" },
    { "key": "password", "value": "Passw0rd!" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (success)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const suffix = Date.now();",
                  "const username = `user_${suffix}`;",
                  "pm.collectionVariables.set('username', username);",
                  "pm.collectionVariables.set('email', `${username}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
                  "pm.collectionVariables.set('access', pm.response.json().access);",
                  "pm.collectionVariables.set('refresh', pm.response.json().refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"password_confirm\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register", ""]
            }
          }
        },
        {
          "name": "Register (error - passwords mismatch)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const suffix = Date.now();",
                  "const username = `user_mismatch_${suffix}`;",
                  "pm.collectionVariables.set('username_mismatch', username);",
                  "pm.collectionVariables.set('email_mismatch', `${username}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('400 Bad Request', function () { pm.response.to.have.status(400); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username_mismatch}}\",\n  \"email\": \"{{email_mismatch}}\",\n  \"password\": \"{{password}}\",\n  \"password_confirm\": \"DIFFERENT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register", ""]
            }
          }
        },
        {
          "name": "Login (success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.collectionVariables.set('access', pm.response.json().access);",
                  "pm.collectionVariables.set('refresh', pm.response.json().refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login", ""]
            }
          }
        },
        {
          "name": "Login (error - invalid credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"WRONG\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login", ""]
            }
          }
        },
        {
          "name": "Get me (no token -> 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me", ""]
            }
          }
        },
        {
          "name": "Get me (with token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me", ""]
            }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.collectionVariables.set('access', pm.response.json().access);",
                  "if (pm.response.json().refresh) { pm.collectionVariables.set('refresh', pm.response.json().refresh); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh", ""]
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.collectionVariables.unset('access');",
                  "pm.collectionVariables.unset('refresh');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout", ""]
            }
          }
        }
      ]
    }
  ]
}

