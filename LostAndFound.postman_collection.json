            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const suffix = Date.now();",
                  "const itemTitle = `Temp item ${suffix}`;",
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/api/items/',",
                  "  method: 'POST',",
                  "  header: {",
                  "    'Content-Type': 'application/json',",
                  "    'Authorization': 'Bearer ' + pm.collectionVariables.get('access')",
                  "  },",
                  "  body: {",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({",
                  "      title: itemTitle,",
                  "      description: 'Temporary item for reject claim test',",
                  "      item_type: 'found',",
                  "      location: 'Test location',",
                  "      date_lost_or_found: '2026-04-10',",
                  "      category: Number(pm.collectionVariables.get('categoryId'))",
                  "    })",
                  "  }",
                  "}, function (err, res) {",
                  "  pm.collectionVariables.set('rejectItemId', res.json().id);",
                  "  pm.sendRequest({",
                  "    url: pm.collectionVariables.get('baseUrl') + '/api/claims/',",
                  "    method: 'POST',",
                  "    header: {",
                  "      'Content-Type': 'application/json',",
                  "      'Authorization': 'Bearer ' + pm.collectionVariables.get('access2')",
                  "    },",
                  "    body: {",
                  "      mode: 'raw',",
                  "      raw: JSON.stringify({",
                  "        item: pm.collectionVariables.get('rejectItemId'),",
                  "        message: 'Please reject this claim after the test.'",
                  "      })",
                  "    }",
                  "  }, function (err2, res2) {",
                  "    pm.collectionVariables.set('rejectClaimId', res2.json().id);",
                  "  });",
                  "});"
                ]
