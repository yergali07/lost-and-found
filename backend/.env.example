# Copy this file to `.env` (which is gitignored) and load it with your shell or
# a tool such as direnv / autoenv before running `python manage.py`.

# Required when DJANGO_DEBUG is False; in DEBUG mode an insecure dev key is used.
DJANGO_SECRET_KEY=replace-with-a-long-random-string

# Set to "False" in production. Defaults to "True".
DJANGO_DEBUG=True

# Comma-separated. Defaults to "localhost,127.0.0.1".
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CORS origins for the SPA. Defaults to the dev frontend.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:4200
